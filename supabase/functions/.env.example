# Variáveis de ambiente para as Edge Functions HOSPEDAH
# Copie este arquivo para .env e preencha os valores reais.
# Configure no Supabase Dashboard → Settings → Edge Functions → Secrets.

# ── OpenWeatherMap (função: weather) ──────────────────────────
OPENWEATHER_API_KEY=sua_chave_openweathermap_aqui

# ── Z-API — WhatsApp (funções: notificacao-reserva, lembrete-checkin) ──
ZAPI_INSTANCE_ID=seu_id_instancia_zapi
ZAPI_TOKEN=seu_token_zapi
WHATSAPP_ADMIN_NUMBER=5517982006382

# ── Resend — E-mail transacional (função: notificacao-reserva) ─
RESEND_API_KEY=re_sua_chave_resend_aqui
RESEND_FROM=HOSPEDAH <noreply@hospedah.tur.br>

# ── OneSignal — Push Notifications (função: recuperacao-abandono) ─
ONESIGNAL_APP_ID=seu_app_id_onesignal
ONESIGNAL_API_KEY=sua_api_key_onesignal

# ── Supabase (funções que acessam o banco via service role) ───
# Estes valores são injetados automaticamente pelo runtime Supabase.
# Não é necessário configurar manualmente.
# SUPABASE_URL=https://ydrmjoppjxtmnwtvtinb.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<gerado automaticamente>
