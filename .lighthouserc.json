{
  "ci": {
    "collect": {
      "startServerCommand": "python3 -m http.server 3000",
      "startServerReadyPattern": "Serving HTTP",
      "startServerReadyTimeout": 15000,
      "numberOfRuns": 1,
      "url": [
        "http://localhost:3000/index.html",
        "http://localhost:3000/reservas.html",
        "http://localhost:3000/busca.html",
        "http://localhost:3000/resorts/hotbeach.html"
      ],
      "settings": {
        "emulatedFormFactor": "mobile",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["warn",  { "minScore": 0.50 }],
        "categories:accessibility":  ["error", { "minScore": 0.85 }],
        "categories:seo":            ["error", { "minScore": 0.90 }],
        "categories:best-practices": ["error", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

